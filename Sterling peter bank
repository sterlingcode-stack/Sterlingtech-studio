    </footer>

    <!-- LOGIN MODAL -->
    <div id="loginModal" class="hidden fixed inset-0 bg-black/70 flex items-center justify-center z-[100]">
        <div class="bg-white rounded-3xl p-10 max-w-md w-full mx-4">
            <h3 class="text-2xl font-bold mb-6">Welcome Back</h3>
            <input type="text" placeholder="Email or Phone" class="w-full p-4 border rounded-2xl mb-4">
            <input type="password" placeholder="Password / PIN" class="w-full p-4 border rounded-2xl mb-6">
            <button class="w-full py-4 bg-blue-700 text-white font-semibold rounded-2xl">Sign In Securely</button>
            <p class="text-center text-sm mt-6 text-gray-500">Demo Mode • No real login required</p>
            <button onclick="toggleLoginModal()" class="mt-6 w-full py-3 text-gray-500">Close</button>
        </div>
    </div>

    <script>
        function toggleLoginModal() {
            document.getElementById('loginModal').classList.toggle('hidden');
        }

        function toggleOnboardingModal() {
            alert("Digital Onboarding Demo:\n\n1. Enter BVN & NIN\n2. Upload ID & Photo\n3. Liveness Check\n4. Account Created in 5 minutes!");
        }

        function calculateLoan() {
            const amount = parseFloat(document.getElementById('loanAmount').value) || 500000;
            const months = parseFloat(document.getElementById('loanMonths').value);
            document.getElementById('monthsValue').textContent = months;
            
            // Simple calculation
            const rate = 0.015; // 1.5% monthly demo rate
            const monthly = (amount * rate * Math.pow(1 + rate, months)) / (Math.pow(1 + rate, months) - 1);
            const totalInterest = (monthly * months) - amount;
            
            document.getElementById('monthlyPay').textContent = '₦' + monthly.toFixed(0).replace(/\B(?=(\d{3})+(?!\d))/g, ",");
            document.getElementById('totalInterest').textContent = '₦' + totalInterest.toFixed(0).replace(/\B(?=(\d{3})+(?!\d))/g, ",");
        }

        // Initialize loan calculator
        window.onload = calculateLoan;

        // Tailwind script already loaded
    </script>
</body>
