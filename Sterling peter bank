                    <li>Current Account</li>
                    <li>Savings Account</li>
                    <li>Loans</li>
                    <li>Cards</li>
                </ul>
            </div>
            <div>
                <h4 class="font-semibold text-white mb-4">Company</h4>
                <ul class="space-y-2 text-sm">
                    <li>About Us</li>
                    <li>Careers</li>
                    <li>Contact</li>
                    <li>Blog</li>
                </ul>
            </div>
            <div>
                <h4 class="font-semibold text-white mb-4">Security</h4>
                <p class="text-xs">128-bit SSL • Biometric Login • AI Fraud Detection</p>
                <p class="mt-6 text-xs">CBN Licensed • Member of NDIC</p>
            </div>
        </div>
        <div class="text-center text-xs mt-12 border-t border-gray-800 pt-8">
