                    <div class="h-2 w-3/4 bg-blue-600 rounded-full"></div>
                </div>
                <p class="text-xs text-gray-500 mt-2">75% of ₦2,850,000 target</p>
            </div>
            
            <div class="bg-white rounded-3xl p-8 dashboard-card shadow">
                <p class="text-gray-500 text-sm">Recent Activity</p>
                <div class="mt-6 space-y-4">
                    <div class="flex justify-between text-sm">
                        <div>
                            <p class="font-medium">Grocery - Shoprite</p>
