        <!-- Transaction History -->
        <div class="mt-12 bg-white rounded-3xl p-8 shadow">
            <div class="flex justify-between mb-6">
                <h3 class="text-xl font-semibold">Transaction History</h3>
                <button class="text-blue-600 text-sm font-medium">Download Statement (PDF) ↓</button>
            </div>
            <table class="w-full">
                <thead>
                    <tr class="border-b text-left text-sm text-gray-500">
                        <th class="pb-4">Date</th>
                        <th class="pb-4">Description</th>
                        <th class="pb-4">Type</th>
                        <th class="pb-4 text-right">Amount</th>
                    </tr>
                </thead>
                <tbody class="text-sm">
                    <tr class="border-b">
                        <td class="py-4">May 29, 2026</td>
                        <td>Transfer to John Doe</td>
                        <td class="text-blue-600">P2P</td>
                        <td class="text-right font-medium">-₦45,000</td>
                    </tr>
                    <tr class="border-b">
                        <td class="py-4">May 28, 2026</td>
                        <td>MTN Airtime</td>
                        <td>Bill Pay</td>
