    <!-- FEATURES GRID -->
    <section class="bg-gray-100 py-16">
        <div class="max-w-7xl mx-auto px-6">
            <h2 class="text-3xl font-bold text-center mb-12">Powerful Banking Features</h2>
            
            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
                <div class="bg-white p-8 rounded-3xl">
                    <i class="fas fa-exchange-alt text-4xl text-blue-600 mb-6"></i>
                    <h3 class="font-semibold text-xl mb-2">Transfers &amp; Payments</h3>
                    <p class="text-gray-600">Local, international, bill pay, and real-time P2P transfers.</p>
                </div>
                
                <div class="bg-white p-8 rounded-3xl">
                    <i class="fas fa-credit-card text-4xl text-blue-600 mb-6"></i>
                    <h3 class="font-semibold text-xl mb-2">Cards Management</h3>
                    <p class="text-gray-600">Virtual &amp; physical cards • Freeze • Set limits • Instant control.</p>
                </div>
                
                <div class="bg-white p-8 rounded-3xl">
                    <i class="fas fa-hand-holding-usd text-4xl text-blue-600 mb-6"></i>
                    <h3 class="font-semibold text-xl mb-2">Loans &amp; Credit</h3>
                    <p class="text-gray-600">Instant loan applications, calculators &amp; approval tracking.</p>
                </div>
                
                <div class="bg-white p-8 rounded-3xl">
                    <i class="fas fa-chart-pie text-4xl text-blue-600 mb-6"></i>
                    <h3 class="font-semibold text-xl mb-2">Personal Finance Tools</h3>
                    <p class="text-gray-600">Budgeting, spending insights &amp; AI recommendations.</p>
                </div>
                
                <div class="bg-white p-8 rounded-3xl">
                    <i class="fas fa-piggy-bank text-4xl text-blue-600 mb-6"></i>
                    <h3 class="font-semibold text-xl mb-2">Investments &amp; Savings</h3>
                    <p class="text-gray-600">Fixed deposits, goal-based savings &amp; investment tracking.</p>
                </div>
                
                <div class="bg-white p-8 rounded-3xl">
                    <i class="fas fa-bell text-4xl text-blue-600 mb-6"></i>
                    <h3 class="font-semibold text-xl mb-2">Smart Notifications</h3>
                    <p class="text-gray-600">Real-time alerts via Email, SMS &amp; Push.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- LOAN CALCULATOR -->
    <section class="max-w-7xl mx-auto px-6 py-16">
        <div class="bg-white rounded-3xl p-10 shadow">
            <h3 class="text-2xl font-bold mb-8">Loan Calculator</h3>
            <div class="grid md:grid-cols-2 gap-10">
                <div>
                    <label class="block text-sm mb-2">Loan Amount (₦)</label>
                    <input type="number" id="loanAmount" value="500000" 
                           class="w-full p-4 border rounded-2xl text-2xl font-medium focus:outline-none focus:border-blue-500">
                    
                    <label class="block text-sm mt-6 mb-2">Duration (Months)</label>
                    <input type="range" id="loanMonths" min="6" max="60" value="24" 
                           class="w-full accent-blue-600" oninput="calculateLoan()">
                    <div class="flex justify-between text-xs text-gray-500 mt-1">
                        <span>6</span><span id="monthsValue">24</span><span>60</span>
                    </div>
                </div>
                <div class="bg-gray-50 rounded-3xl p-8">
                    <p class="text-gray-500">Estimated Monthly Payment</p>
                    <p id="monthlyPay" class="text-5xl font-bold text-blue-700 mt-3">₦24,850</p>
                    <p class="text-sm text-gray-500 mt-8">Total Interest: <span id="totalInterest" class="font-medium">₦96,400</span></p>
                </div>
            </div>
        </div>
    </section>

    <!-- FOOTER -->
    <footer class="bg-gray-900 text-gray-400 py-16">
        <div class="max-w-7xl mx-auto px-6 grid md:grid-cols-4 gap-10">
            <div>
