    <!-- MOCK DASHBOARD -->
    <section id="dashboard-section" class="max-w-7xl mx-auto px-6 py-16">
        <h2 class="text-3xl font-bold text-center mb-12">Account Dashboard</h2>
        
        <div class="grid md:grid-cols-3 gap-6">
